{
  "name": "check_ru_compact_input_v2_6_4_check_policies",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "grade",
      "check_flow",
      "actions_payload",
      "limits"
    ],
    "properties": {
      "grade": {
        "type": "integer",
        "enum": [
          1,
          2,
          3,
          4
        ]
      },
      "check_flow": {
        "type": "string",
        "enum": [
          "ready",
          "need_retake",
          "unsupported",
          "cannot_check"
        ]
      },
      "actions_payload": {
        "type": "array",
        "minItems": 1,
        "maxItems": 6,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_id",
            "template_id",
            "task_action",
            "check_mode",
            "rule_family",
            "sub_rule_key",
            "reliability",
            "answer_reliability",
            "check_strategy",
            "relevant_rules",
            "anti_gdz_bans",
            "source_items",
            "check_items"
          ],
          "properties": {
            "action_id": {
              "type": "string",
              "maxLength": 40
            },
            "template_id": {
              "type": "string",
              "maxLength": 80
            },
            "task_action": {
              "type": "string",
              "maxLength": 80
            },
            "check_mode": {
              "type": "string",
              "enum": [
                "strict",
                "semi_strict",
                "contextual",
                "rubric",
                "visual"
              ]
            },
            "rule_family": {
              "type": "string",
              "maxLength": 80
            },
            "sub_rule_key": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 80
            },
            "reliability": {
              "type": "string",
              "enum": [
                "high",
                "medium",
                "low",
                "none"
              ]
            },
            "answer_reliability": {
              "type": "string",
              "enum": [
                "high",
                "medium",
                "low",
                "none"
              ]
            },
            "check_strategy": {
              "type": "string",
              "maxLength": 900
            },
            "relevant_rules": {
              "type": "array",
              "minItems": 0,
              "maxItems": 3,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "rule_id",
                  "title",
                  "short_rule"
                ],
                "properties": {
                  "rule_id": {
                    "type": "string",
                    "maxLength": 80
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 100
                  },
                  "short_rule": {
                    "type": "string",
                    "maxLength": 350
                  }
                }
              }
            },
            "anti_gdz_bans": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "items": {
                "type": "string",
                "maxLength": 180
              }
            },
            "source_items": {
              "type": "array",
              "minItems": 0,
              "maxItems": 12,
              "items": {
                "type": "string",
                "maxLength": 200
              }
            },
            "check_items": {
              "type": "array",
              "minItems": 0,
              "maxItems": 12,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "source_item",
                  "student_answer",
                  "answer_readability"
                ],
                "properties": {
                  "source_item": {
                    "type": "string",
                    "maxLength": 200
                  },
                  "student_answer": {
                    "type": "string",
                    "maxLength": 200
                  },
                  "answer_readability": {
                    "type": "string",
                    "enum": [
                      "high",
                      "medium",
                      "low",
                      "none"
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "limits": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "max_error_groups",
          "max_rule_buttons"
        ],
        "properties": {
          "max_error_groups": {
            "type": "integer",
            "enum": [
              1,
              2,
              3
            ]
          },
          "max_rule_buttons": {
            "type": "integer",
            "enum": [
              0,
              1,
              2,
              3
            ]
          }
        }
      }
    },
    "description": "CHECK_RU compact input for v2.6 final reference rules. relevant_rules use short_rule. Output status remains compatible: correct|almost|needs_fix|cannot_check."
  }
}